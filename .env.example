# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5434/crop_risk_db
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=crop_risk_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery Configuration (for auto-processing)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=change-this-to-a-random-secret-key-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=Crop Risk Prediction Platform
DEBUG=True
DISEASE_MODEL_VERSION=1.0.0

# External APIs
SENTINEL_API_KEY=your-sentinel-api-key
WEATHER_API_KEY=your-weather-api-key

# Google Earth Engine (for Real Satellite Data Processing)
# OAuth method - credentials stored in data/earthengine/credentials
GEE_PROJECT=your-gcp-project-id

# OR Service Account method (for production)
# GEE_SERVICE_ACCOUNT_EMAIL=your-account@your-project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY_PATH=/app/data/earthengine/private-key.json

# Fallback option (uses simulated data - not recommended)
USE_PLANETARY_COMPUTER=false

# Weather Data Sources (for Stress Detection)
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHERAPI_KEY=your-weatherapi-key

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SMS (Africa's Talking)
SMS_PROVIDER=africas_talking
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=sandbox

# Storage
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
S3_BUCKET_NAME=crop-risk-data

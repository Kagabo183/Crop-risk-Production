# ============================================================================
# CROP RISK PREDICTION PLATFORM — ENVIRONMENT CONFIGURATION
# ============================================================================
# Production deployment on Render + Vercel
# Copy this file to .env and customize for your environment

# ============================================================================
# DATABASE (PostgreSQL with PostGIS)
# ============================================================================
# Local development: localhost:5434
# Render managed: Use the internal PostgreSQL service URL provided by Render
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:your_password@localhost:5434/crop_risk_db
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=crop_risk_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# ============================================================================
# REDIS (Cache & Celery Broker)
# ============================================================================
# Local development: localhost:6379
# Render managed: Use the Render Redis service URL provided
# Format: redis://[:password@]host:port/db_number
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# JWT AUTHENTICATION & SECURITY
# ============================================================================
# Generate with: openssl rand -hex 32
# IMPORTANT: Change these values in production!
SECRET_KEY=change-this-to-a-random-secret-key-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# API SETTINGS
# ============================================================================
API_V1_STR=/api/v1
PROJECT_NAME=Crop Risk Prediction Platform
DEBUG=False  # Set to False in production
ENVIRONMENT=production  # Options: development, staging, production

# ============================================================================
# ML MODELS
# ============================================================================
MODEL_DIR=./backend/data/models
DISEASE_MODEL_VERSION=1.0.0

# ============================================================================
# SATELLITE DATA (Google Earth Engine)
# ============================================================================
# Sets the GEE project ID
GEE_PROJECT=your-gcp-project-id

# Service account authentication (REQUIRED for production)
# 1. Create a service account in Google Cloud Console
# 2. Download the JSON key file
# 3. Mount it into the container — DO NOT commit the file to git:
#      volumes:
#        - ./keys/gee-service-account.json:/app/keys/gee-service-account.json:ro
# 4. Set the path below to the container-side path:
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=/app/keys/gee-service-account.json

# Disable local satellite storage to save disk space
SATELLITE_LOCAL_STORAGE_ENABLED=false

# ============================================================================
# SATELLITE FALLBACK — Microsoft Planetary Computer STAC
# ============================================================================
# Public STAC catalogue — no API key needed.
# Change only if you have a private STAC endpoint.
MICROSOFT_PLANETARY_COMPUTER_API_STATIC_DOCUMENT=https://planetarycomputer.microsoft.com/api/stac/v1
# Set to true to PREFER Planetary Computer over GEE
USE_PLANETARY_COMPUTER=false

# ============================================================================
# WEATHER & CLIMATE DATA
# ============================================================================
# ERA5 — Copernicus Climate Data Store
# Register free at https://cds.climate.copernicus.eu/
# API key format: UID:API_KEY  (both found in your CDS profile)
ERA5_API_KEY=your-cds-uid:your-cds-api-key
ERA5_API_URL=https://cds.climate.copernicus.eu/api/v2

# NOAA Climate Data Online (CDO)
# Register free at https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_KEY=your-noaa-cdo-token

# IBM Environmental Intelligence Suite (optional)
IBM_EIS_API_KEY=your-ibm-key

# Generic weather API key (fallback)
WEATHER_API_KEY=your-weather-api-key

OPENWEATHER_API_KEY=your-openweather-api-key
WEATHERAPI_KEY=your-weatherapi-key

# ============================================================================
# FILE UPLOADS
# ============================================================================
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# ============================================================================
# CORS & FRONTEND URLS
# ============================================================================
# For Vercel deployment, add your Vercel domain here
FRONTEND_URL=http://localhost:3000
VERCEL_DOMAIN=your-project.vercel.app   # Update with actual Vercel domain

# ============================================================================
# NOTIFICATIONS (Email & SMS)
# ============================================================================
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@cropriskalert.com

# SMS (Africa's Talking)
SMS_PROVIDER=africas_talking
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=sandbox
SMS_FROM=CropRisk

# ============================================================================
# EXTERNAL APIS
# ============================================================================
SENTINEL_API_KEY=your-sentinel-api-key
MAPBOX_TOKEN=pk.your-mapbox-public-token
MAP_API_KEY=your-mapbox-api-key

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info  # Options: debug, info, warning, error, critical
SENTRY_DSN=  # Optional: Sentry error tracking

# ============================================================================
# PRODUCTION RENDER CONFIGURATION
# ============================================================================
# These are automatically set by Render, but included here for reference:
# - DATABASE_URL: Render PostgreSQL internal URL
# - REDIS_URL: Render Redis internal URL
# - ENVIRONMENT: Set to "production"
# - Render automatically sets PORT=8000 for web service

# ============================================================================
# ADVANCED/OPTIONAL
# ============================================================================
# Celery worker concurrency
CELERY_CONCURRENCY=4

# Max retries for failed tasks
MAX_RETRIES=3

# Background task timeout (seconds)
TASK_TIMEOUT=3600

# Enable/disable specific features
ENABLE_SATELLITE_MONITORING=true
ENABLE_DISEASE_FORECASTING=true
ENABLE_ML_MODELS=true
ENABLE_STRESS_DETECTION=true
WEATHER_API_KEY=your-weather-api-key

# Google Earth Engine (for Real Satellite Data Processing)
# Project ID
GEE_PROJECT=your-gcp-project-id

# Service Account method (for production) — see GEE section above
# GEE_SERVICE_ACCOUNT_EMAIL=your-account@your-project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY_PATH=/app/keys/gee-service-account.json

# Satellite fallback (Planetary Computer STAC) — no key needed
USE_PLANETARY_COMPUTER=false
MICROSOFT_PLANETARY_COMPUTER_API_STATIC_DOCUMENT=https://planetarycomputer.microsoft.com/api/stac/v1

# Weather Data Sources (for Stress Detection)
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHERAPI_KEY=your-weatherapi-key

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SMS (Africa's Talking)
SMS_PROVIDER=africas_talking
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=sandbox

# Storage
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-north-1
S3_BUCKET_NAME=your-s3-bucket-name
